# Stage 1: Build Go binary
FROM golang:1.25-alpine AS go-builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
RUN CGO_ENABLED=0 GOOS=linux go build -o /hermes-cluster ./cmd/cluster

# Stage 2: Hermes Agent + plugin
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential && \
    rm -rf /var/lib/apt/lists/*

# Install Hermes Agent
RUN git clone --depth 1 https://github.com/NousResearch/hermes-agent.git /opt/hermes-agent
WORKDIR /opt/hermes-agent
RUN pip install --no-cache-dir -e . 2>&1 | tail -3

# Copy Go binary from stage 1
COPY --from=go-builder /hermes-cluster /usr/local/bin/hermes-cluster
RUN chmod +x /usr/local/bin/hermes-cluster

# Copy plugin
COPY plugins/hermes-agent-cluster/ /root/.hermes/plugins/hermes-agent-cluster/

# Copy config
COPY configs/ /root/.hermes/agent-cluster/

RUN mkdir -p /root/.hermes

WORKDIR /root
ENTRYPOINT ["hermes"]
